# Fieldflow env template
# For Bolt or any hosted environment, set these values in the host's Environment Variables UI.
# Do not rely on a committed `.env` file inside the repo tree.

# Public app URL
NEXT_PUBLIC_APP_URL=https://john123-05-automatio-ffon.bolt.host

# Website access password
APP_ACCESS_PASSWORD=change-me

# Google Places / Maps
GOOGLE_MAPS_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_ADMIN_KEY=
OPENAI_MODEL=gpt-5-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth / Gmail
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://john123-05-automatio-ffon.bolt.host/api/mailboxes/google/callback

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Background polling / scheduler
INBOX_AUTO_SYNC_ENABLED=true
INBOX_POLL_INTERVAL_SECONDS=60
SCHEDULER_SECRET=change-me-long-random-string

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud billing
# Important: for hosted deployments, paste the full JSON as a single-line string.
# Do not use a local file path like /Users/.../service-account.json on Bolt.
GCP_BIGQUERY_SERVICE_ACCOUNT_JSON=
GCP_BILLING_EXPORT_PROJECT_ID=
GCP_BILLING_EXPORT_DATASET=
GCP_BILLING_EXPORT_TABLE=
GCP_TRIAL_START_DATE=
GCP_TRIAL_LENGTH_DAYS=90
GCP_TRIAL_TOTAL_CREDIT_USD=
GCP_BILLING_MANUAL_CURRENCY=EUR
GCP_BILLING_MANUAL_MONTH_TO_DATE_COST=
GCP_BILLING_MANUAL_SPEND_SINCE_TRIAL_START=
GCP_BILLING_MANUAL_REMAINING_CREDIT=

# Private documents
# Leave DOCUMENTS_DIR blank on Bolt unless you mount a real private directory.
# Prefer private Supabase storage for hosted deployments.
DOCUMENTS_DIR=
DOCUMENTS_UPLOAD_DIR=
DOCUMENTS_ACCESS_PASSWORD=
SUPABASE_DOCUMENTS_BUCKET=
SUPABASE_DOCUMENTS_PREFIX=
